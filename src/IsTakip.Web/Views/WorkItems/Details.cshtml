@model WorkItemDetailsPageVM
@{
    ViewData["Title"] = Model.Item.Key;
    var item = Model.Item;
}
<div class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">İş Yönetimi</a>
    <span class="sep">/</span>
    <a asp-action="Index">Görevler</a>
    <span class="sep">/</span>
    <span class="cell-flex">
        <span class="type-icon" title="@item.TypeName"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="9 11 12 14 20 6"/></svg></span>
        @item.Key
    </span>
</div>

<div class="page-head-row" style="align-items:center;margin-bottom:8px">
    <h1 class="page-title" style="margin:0">@item.Title</h1>
    @if (Model.IsManager)
    {
        <form asp-action="Delete" method="post" onsubmit="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@item.Id" />
            <button type="submit" class="btn btn-default" style="color:#AE2A19">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                Sil
            </button>
        </form>
    }
</div>

<!-- Durum değiştirici: herkes Tamamlandı/kapanış dışındaki durumlara alabilir -->
<form asp-action="ChangeState" method="post" class="status-changer" style="margin-bottom:24px">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@item.Id" />
    <select name="toStateId" class="select">
        @foreach (var s in Model.States)
        {
            var isDone = s.Category == StateCategory.Tamamlandi;
            if (isDone && !Model.IsManager && s.Id != item.CurrentStateId)
            {
                continue; // kapanış durumlarını yönetici olmayanlara gösterme
            }
            <option value="@s.Id" selected="@(s.Id == item.CurrentStateId)">@s.Name</option>
        }
    </select>
    <button type="submit" class="btn btn-primary">Durumu Güncelle</button>
    @if (!Model.IsManager)
    {
        <span class="muted" style="font-size:12px">Tamamlama/kapatma yetkisi yöneticilerdedir.</span>
    }
</form>

<div class="detail-grid">
    <div>
        <div class="desc-block">
            <h3>Açıklama</h3>
            <div>@(string.IsNullOrWhiteSpace(item.Description) ? "Açıklama eklenmemiş." : item.Description)</div>
        </div>

        <div class="comments">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                <h3 style="margin:0">Onay Süreci</h3>
                @if (Model.Approval == null)
                {
                    <a class="btn btn-subtle" asp-controller="Approval" asp-action="Start" asp-route-workItemId="@item.Id">Onay Başlat</a>
                }
                else
                {
                    <span class="lozenge" style="--lz:@Model.Approval.StatusColor">@Model.Approval.StatusText</span>
                }
            </div>
            @if (Model.Approval != null)
            {
                <div class="card" style="margin-bottom:8px">
                    @foreach (var s in Model.Approval.Steps)
                    {
                        <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--ds-border)">
                            <span class="avatar sm" style="background:@UiHelpers.AvatarColor(s.ApproverName)">@UiHelpers.Initials(s.ApproverName)</span>
                            <div style="flex:1">
                                <div style="font-size:13px"><strong>@s.Order.</strong> @s.ApproverName</div>
                                @if (!string.IsNullOrEmpty(s.Comment)) { <div class="muted" style="font-size:12px">@s.Comment</div> }
                            </div>
                            @if (s.IsMyActiveStep)
                            {
                                <form asp-controller="Approval" asp-action="Decide" method="post" style="display:flex;gap:6px;align-items:center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="stepId" value="@s.StepId" />
                                    <input type="text" name="comment" class="input" placeholder="Yorum" style="width:150px;height:32px" />
                                    <button type="submit" name="approve" value="true" class="btn btn-primary">Onayla</button>
                                    <button type="submit" name="approve" value="false" class="btn btn-default" style="color:#AE2A19">Reddet</button>
                                </form>
                            }
                            else
                            {
                                <span class="lozenge" style="--lz:@s.StatusColor">@s.StatusText</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="comments">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                <h3 style="margin:0">Alt Görevler (@Model.Subtasks.Count)</h3>
                <a class="btn btn-subtle" asp-action="Create" asp-route-parentId="@item.Id">+ Alt görev ekle</a>
            </div>
            @if (Model.Subtasks.Any())
            {
                <div class="card" style="margin-bottom:8px">
                    @foreach (var st in Model.Subtasks)
                    {
                        <a asp-action="Details" asp-route-id="@st.Id" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--ds-border);color:var(--ds-text)">
                            <span class="type-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="9 11 12 14 20 6"/></svg></span>
                            <span class="issue-key">@st.Key</span>
                            <span style="flex:1;@(st.IsDone ? "text-decoration:line-through;color:var(--ds-text-subtlest)" : "")">@st.Title</span>
                            <span class="lozenge" style="--lz:@(st.StateColor ?? "#5E6C84")">@st.StateName</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="muted" style="font-size:13px;margin-top:0">Alt görev yok.</p>
            }
        </div>

        <div class="comments">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                <h3 style="margin:0">Ekler (@Model.Attachments.Count)</h3>
            </div>
            <form asp-controller="Attachments" asp-action="Upload" method="post" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;margin-bottom:12px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="workItemId" value="@item.Id" />
                <input type="file" name="file" class="input" style="padding:6px" required />
                <button type="submit" class="btn btn-primary">Yükle</button>
            </form>
            @if (Model.Attachments.Any())
            {
                <div class="card">
                    @foreach (var a in Model.Attachments)
                    {
                        <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--ds-border)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#42526E" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                            <div style="flex:1">
                                <a asp-controller="Attachments" asp-action="Download" asp-route-id="@a.Id" style="font-weight:600;color:var(--ds-brand)">@a.FileName</a>
                                <div class="muted" style="font-size:12px">@a.SizeText · @(a.UploaderName ?? "—") · @a.UploadedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                            @if (Model.IsManager)
                            {
                                <form asp-controller="Attachments" asp-action="Delete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Dosya silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-default" style="color:#AE2A19">Sil</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="muted" style="font-size:13px;margin-top:0">Henüz dosya eklenmemiş.</p>
            }
        </div>

        <div class="comments">
            <h3>Yorumlar (@Model.Comments.Count)</h3>

            <div class="comment">
                <span class="avatar" style="background:@UiHelpers.AvatarColor(User.Identity!.Name)">@UiHelpers.Initials(User.Identity!.Name)</span>
                <form asp-action="AddComment" method="post" style="flex:1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <textarea name="body" class="input" rows="3" placeholder="Bir yorum ekleyin..." required></textarea>
                    <div style="margin-top:8px">
                        <button type="submit" class="btn btn-primary">Yorum Ekle</button>
                    </div>
                </form>
            </div>

            @foreach (var c in Model.Comments)
            {
                <div class="comment">
                    <span class="avatar" style="background:@UiHelpers.AvatarColor(c.AuthorName)">@UiHelpers.Initials(c.AuthorName)</span>
                    <div class="c-body">
                        <div class="c-head">
                            <span class="c-name">@c.AuthorName</span>
                            <span class="c-time">@c.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                        <div class="c-text">@c.Body</div>
                    </div>
                </div>
            }
            @if (!Model.Comments.Any())
            {
                <p class="muted" style="font-size:13px">Henüz yorum yok. İlk yorumu siz ekleyin.</p>
            }
        </div>
    </div>

    <aside class="detail-side">
        <div class="ds-head">Detaylar</div>
        <div class="detail-row">
            <dt>Durum</dt>
            <dd><span class="lozenge" style="--lz:#0C66E4">@item.StateName</span></dd>
        </div>
        <div class="detail-row">
            <dt>Tür</dt>
            <dd>@item.TypeName</dd>
        </div>
        <div class="detail-row">
            <dt>Öncelik</dt>
            <dd>@(item.PriorityName ?? "—")</dd>
        </div>
        <div class="detail-row">
            <dt>Sorumlu</dt>
            <dd>
                @if (item.AssigneeName != null)
                {
                    <span class="cell-flex"><span class="avatar sm" style="background:@UiHelpers.AvatarColor(item.AssigneeName)">@UiHelpers.Initials(item.AssigneeName)</span>@item.AssigneeName</span>
                }
                else { <span class="muted">Atanmamış</span> }
            </dd>
        </div>
        <div class="detail-row">
            <dt>Talep Eden</dt>
            <dd>
                @if (item.ReporterName != null)
                {
                    <span class="cell-flex"><span class="avatar sm" style="background:@UiHelpers.AvatarColor(item.ReporterName)">@UiHelpers.Initials(item.ReporterName)</span>@item.ReporterName</span>
                }
                else { <span class="muted">—</span> }
            </dd>
        </div>
        <div class="detail-row">
            <dt>Başlangıç</dt>
            <dd>@(item.StartDate?.ToString("dd MMM yyyy") ?? "—")</dd>
        </div>
        <div class="detail-row">
            <dt>Son Tarih</dt>
            <dd>@(item.DueDate?.ToString("dd MMM yyyy") ?? "—")</dd>
        </div>
        <div class="detail-row">
            <dt>SLA Durumu</dt>
            <dd><span class="lozenge" style="--lz:@Model.SlaColor">@Model.SlaText</span></dd>
        </div>
        <div class="detail-row">
            <dt>Oluşturma</dt>
            <dd>@item.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
        </div>
        @foreach (var cf in Model.CustomFields)
        {
            <div class="detail-row">
                <dt>@cf.Name</dt>
                <dd>@cf.Value</dd>
            </div>
        }
    </aside>
</div>
