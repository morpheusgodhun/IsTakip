@model AiChatVM
@{ ViewData["Title"] = "AI Asistan"; }
<div class="breadcrumbs"><a asp-controller="Home" asp-action="Index">İş Yönetimi</a><span class="sep">/</span><span>AI Asistan</span></div>
<h1 class="page-title">AI Asistan</h1>

@if (!Model.IsConfigured)
{
    <div class="flash err" style="margin-bottom:16px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        AI servisi yapılandırılmamış. <code>appsettings.json</code> → <code>"Gemini:ApiKey"</code> alanına anahtarınızı girin.
    </div>
}

<div class="card card-pad" style="max-width:820px">
    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <div class="field">
            <label for="prompt">Sorunuz / isteğiniz</label>
            <textarea id="prompt" name="prompt" class="input" rows="4" placeholder="Örn: 'Aşağıdaki görev açıklamasını müşteriye uygun bir dille özetle...'">@Model.Prompt</textarea>
        </div>
        <button type="submit" class="btn btn-primary">Gönder</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.Answer))
    {
        <div style="margin-top:20px;border-top:1px solid var(--ds-border);padding-top:16px">
            <div class="panel-title" style="margin-bottom:8px">Yanıt</div>
            <div style="white-space:pre-wrap;line-height:1.6">@Model.Answer</div>
        </div>
    }
</div>
