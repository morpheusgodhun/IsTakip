@model List<IsTakip.Domain.Entities.Notification>
@{
    ViewData["Title"] = "Bildirimler";
}
<div class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">İş Yönetimi</a>
    <span class="sep">/</span><span>Bildirimler</span>
</div>
<div class="page-head-row">
    <h1 class="page-title">Bildirimler</h1>
    <form asp-action="MarkAllRead" method="post">@Html.AntiForgeryToken()<button class="btn btn-subtle" type="submit">Tümünü okundu işaretle</button></form>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div class="table-empty">Bildiriminiz yok.</div>
    }
    @foreach (var n in Model)
    {
        <a href="@(string.IsNullOrEmpty(n.LinkUrl) ? "#" : n.LinkUrl)"
           style="display:flex;gap:12px;padding:14px 18px;border-bottom:1px solid var(--ds-border);@(n.IsRead ? "" : "background:var(--ds-brand-subtle)")">
            <span class="avatar sm" style="background:#0C66E4">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg>
            </span>
            <div style="flex:1">
                <div style="font-weight:@(n.IsRead ? "500" : "600");color:var(--ds-text)">@n.Title</div>
                @if (!string.IsNullOrEmpty(n.Body)) { <div class="muted" style="font-size:13px">@n.Body</div> }
                <div class="muted" style="font-size:12px;margin-top:2px">@n.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
            </div>
        </a>
    }
</div>
