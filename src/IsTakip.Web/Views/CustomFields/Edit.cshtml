@model CustomFieldEditVM
@{ var isNew = Model.Id == 0; ViewData["Title"] = isNew ? "Yeni Alan" : "Alan Düzenle"; }
<div class="breadcrumbs"><a asp-controller="Home" asp-action="Index">İş Yönetimi</a><span class="sep">/</span><a asp-action="Index">Form Tasarımcısı</a><span class="sep">/</span><span>@(isNew ? "Yeni" : Model.Name)</span></div>
<h1 class="page-title">@(isNew ? "Yeni alan" : "Alan düzenle")</h1>
<div class="card card-pad" style="max-width:640px">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        @if (!ViewData.ModelState.IsValid) { <div class="form-errors" asp-validation-summary="All"></div> }
        <div class="field"><label asp-for="Name">Alan Adı<span class="req">*</span></label><input asp-for="Name" class="input" /></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div class="field"><label asp-for="FieldType">Alan Türü</label><select asp-for="FieldType" asp-items="Model.FieldTypes" class="select"></select></div>
            <div class="field"><label asp-for="WorkItemTypeId">Görev Türü</label><select asp-for="WorkItemTypeId" asp-items="Model.WorkItemTypes" class="select"><option value="">Tüm türler</option></select></div>
        </div>
        <div class="field"><label asp-for="SortOrder">Sıra</label><input asp-for="SortOrder" type="number" class="input" /></div>
        <label style="display:flex;align-items:center;gap:8px;margin-bottom:14px"><input type="checkbox" asp-for="IsRequired" style="width:16px;height:16px" /> Zorunlu alan</label>
        <div class="field">
            <label asp-for="OptionsText">Seçenekler</label>
            <textarea asp-for="OptionsText" class="input" rows="4" placeholder="Yalnızca 'Seçim' türlerinde kullanılır. Her satıra bir seçenek yazın."></textarea>
        </div>
        <div style="display:flex;gap:10px"><button type="submit" class="btn btn-primary">Kaydet</button><a asp-action="Index" class="btn btn-subtle">Vazgeç</a></div>
    </form>
</div>
