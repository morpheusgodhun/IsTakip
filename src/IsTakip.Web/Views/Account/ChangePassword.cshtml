@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}
<div class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">İş Yönetimi</a>
    <span class="sep">/</span>
    <span>Şifre değiştir</span>
</div>
<h1 class="page-title">Şifre değiştir</h1>

<div class="card card-pad" style="max-width:480px">
    <form asp-controller="Account" asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="form-errors" asp-validation-summary="All"></div>
        }
        <div class="field">
            <label asp-for="CurrentPassword">Mevcut Parola<span class="req">*</span></label>
            <input asp-for="CurrentPassword" class="input" type="password" autocomplete="current-password" />
        </div>
        <div class="field">
            <label asp-for="NewPassword">Yeni Parola<span class="req">*</span></label>
            <input asp-for="NewPassword" class="input" type="password" autocomplete="new-password" />
            <div class="field-hint">En az 8 karakter, büyük harf, rakam ve sembol içermeli.</div>
        </div>
        <div class="field">
            <label asp-for="ConfirmPassword">Yeni Parola (Tekrar)<span class="req">*</span></label>
            <input asp-for="ConfirmPassword" class="input" type="password" autocomplete="new-password" />
        </div>
        <div style="display:flex;gap:10px;margin-top:8px">
            <button type="submit" class="btn btn-primary">Parolayı Güncelle</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-subtle">Vazgeç</a>
        </div>
    </form>
</div>
