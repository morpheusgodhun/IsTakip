@model LoginViewModel
@{
    ViewData["Title"] = "Giriş";
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">
            <span class="lm">K</span>
            <div style="text-align:center">
                <div style="font-weight:700;font-size:18px;color:var(--ds-text)">İş Takip Uygulaması</div>
                <div class="lt">Kurumsal İş &amp; Süreç Yönetimi</div>
            </div>
        </div>
        <div class="auth-panel">
            <h1>Hesabınıza giriş yapın</h1>
            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="form-errors" asp-validation-summary="All"></div>
                }
                <div class="field">
                    <label asp-for="UserName">Kullanıcı Adı</label>
                    <input asp-for="UserName" class="input" autocomplete="username" placeholder="kullanici.adi" />
                </div>
                <div class="field">
                    <label asp-for="Password">Parola</label>
                    <input asp-for="Password" class="input" type="password" autocomplete="current-password" placeholder="••••••••" />
                </div>
                <button type="submit" class="btn btn-primary btn-lg btn-block">Giriş Yap</button>
            </form>
        </div>
    </div>
</div>
