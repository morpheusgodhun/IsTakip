@model List<IsTakip.Domain.Entities.InventoryCategory>
@{ ViewData["Title"] = "Envanter Kategorileri"; }
<div class="breadcrumbs"><a asp-controller="Home" asp-action="Index">İş Yönetimi</a><span class="sep">/</span><a asp-action="Index">Envanter</a><span class="sep">/</span><span>Kategoriler</span></div>
<h1 class="page-title">Envanter Türleri / Kategorileri</h1>
<div class="card card-pad" style="max-width:520px;margin-bottom:16px">
    <form asp-action="CategoryCreate" method="post" style="display:flex;gap:8px;align-items:flex-end">
        @Html.AntiForgeryToken()
        <div class="field" style="flex:1;margin:0"><label>Yeni kategori</label><input type="text" name="name" class="input" placeholder="Örn. Laptop, Telefon, Araç" required /></div>
        <button type="submit" class="btn btn-primary">Ekle</button>
    </form>
</div>
<table class="issue-table" style="max-width:520px">
    <thead><tr><th>Kategori</th><th style="width:90px"></th></tr></thead>
    <tbody>
        @if (!Model.Any()) { <tr><td colspan="2"><div class="table-empty">Kategori yok.</div></td></tr> }
        @foreach (var c in Model)
        {
            <tr><td>@c.Name</td><td><form asp-action="CategoryDelete" asp-route-id="@c.Id" method="post" onsubmit="return confirm('Silinsin mi?');">@Html.AntiForgeryToken()<button class="btn btn-default" style="color:#AE2A19">Sil</button></form></td></tr>
        }
    </tbody>
</table>
