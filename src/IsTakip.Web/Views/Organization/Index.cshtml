@model OrgTreeVM
@{
    ViewData["Title"] = "Organizasyon";
}
<div class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">İş Yönetimi</a>
    <span class="sep">/</span><span>Organizasyon</span>
</div>
<div class="page-head-row">
    <h1 class="page-title">Organizasyon Yapısı</h1>
    <div style="display:flex;gap:8px">
        <a class="btn btn-default" asp-action="Branch">+ Şube</a>
        <a class="btn btn-default" asp-action="Department">+ Departman</a>
        <a class="btn btn-default" asp-action="Team">+ Takım</a>
        <a class="btn btn-primary" asp-action="Company">+ Şirket</a>
    </div>
</div>

@if (!Model.Companies.Any())
{
    <div class="card card-pad"><div class="table-empty">Henüz şirket eklenmemiş. "+ Şirket" ile başlayın.</div></div>
}

@foreach (var c in Model.Companies)
{
    <div class="card card-pad" style="margin-bottom:16px">
        <div style="display:flex;align-items:center;justify-content:space-between">
            <div class="cell-flex">
                <span class="proj-avatar" style="width:28px;height:28px;border-radius:6px">@(c.Name.Length > 0 ? c.Name.Substring(0,1) : "?")</span>
                <strong style="font-size:16px">@c.Name</strong>
                @if (c.TaxNumber != null) { <span class="muted" style="font-size:12px">VKN: @c.TaxNumber</span> }
                @if (!c.IsActive) { <span class="lozenge" style="--lz:#5E6C84">Pasif</span> }
            </div>
            <div style="display:flex;gap:6px">
                <a class="btn btn-subtle" asp-action="CompanyEdit" asp-route-id="@c.Id">Düzenle</a>
                <form asp-action="CompanyDelete" asp-route-id="@c.Id" method="post" onsubmit="return confirm('Şirketi silmek istiyor musunuz?');">@Html.AntiForgeryToken()<button class="btn btn-default" style="color:#AE2A19">Sil</button></form>
            </div>
        </div>

        <div style="margin-top:12px;padding-left:14px;border-left:2px solid var(--ds-border)">
            @foreach (var b in c.Branches)
            {
                <div style="margin:10px 0">
                    <div class="cell-flex">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#42526E" stroke-width="2"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg>
                        <strong>@b.Name</strong>
                        <a class="muted" asp-action="Branch" asp-route-id="@b.Id" style="font-size:12px">düzenle</a>
                        <form asp-action="BranchDelete" asp-route-id="@b.Id" method="post" style="display:inline" onsubmit="return confirm('Şubeyi silmek istiyor musunuz?');">@Html.AntiForgeryToken()<button class="muted" style="background:none;border:none;cursor:pointer;font-size:12px;color:#AE2A19">sil</button></form>
                    </div>
                    <div style="padding-left:22px">
                        @foreach (var d in b.Departments)
                        {
                            <div style="margin:6px 0">
                                <div class="cell-flex">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6554C0" stroke-width="2"><rect x="3" y="7" width="18" height="14" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    <span>@d.Name</span>
                                    @if (d.ManagerName != null) { <span class="muted" style="font-size:12px">· Müdür: @d.ManagerName</span> }
                                    <a class="muted" asp-action="Department" asp-route-id="@d.Id" style="font-size:12px">düzenle</a>
                                    <form asp-action="DepartmentDelete" asp-route-id="@d.Id" method="post" style="display:inline" onsubmit="return confirm('Departmanı silmek istiyor musunuz?');">@Html.AntiForgeryToken()<button class="muted" style="background:none;border:none;cursor:pointer;font-size:12px;color:#AE2A19">sil</button></form>
                                </div>
                                <div style="padding-left:22px">
                                    @foreach (var t in d.Teams)
                                    {
                                        <div class="cell-flex" style="margin:4px 0;font-size:13px">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#00857A" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                            <span>@t.Name</span>
                                            @if (t.LeadName != null) { <span class="muted">· Lider: @t.LeadName</span> }
                                            <span class="muted">· @t.MemberCount üye</span>
                                            <a class="muted" asp-action="Team" asp-route-id="@t.Id" style="font-size:12px">düzenle</a>
                                            <form asp-action="TeamDelete" asp-route-id="@t.Id" method="post" style="display:inline" onsubmit="return confirm('Takımı silmek istiyor musunuz?');">@Html.AntiForgeryToken()<button class="muted" style="background:none;border:none;cursor:pointer;font-size:12px;color:#AE2A19">sil</button></form>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
