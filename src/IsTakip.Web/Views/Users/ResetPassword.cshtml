@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}
<div class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">İş Yönetimi</a>
    <span class="sep">/</span>
    <a asp-action="Index">Kullanıcılar</a>
    <span class="sep">/</span>
    <span>Şifre sıfırla</span>
</div>
<h1 class="page-title">Şifre sıfırla</h1>

<div class="card card-pad" style="max-width:480px">
    <p class="muted" style="margin-top:0">Kullanıcı: <strong style="color:var(--ds-text)">@Model.FullName</strong></p>
    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="FullName" />
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="form-errors" asp-validation-summary="All"></div>
        }
        <div class="field">
            <label asp-for="NewPassword">Yeni Parola<span class="req">*</span></label>
            <input asp-for="NewPassword" class="input" type="password" />
            <div class="field-hint">En az 8 karakter, büyük harf, rakam ve sembol içermeli.</div>
        </div>
        <div class="field">
            <label asp-for="ConfirmPassword">Yeni Parola (Tekrar)<span class="req">*</span></label>
            <input asp-for="ConfirmPassword" class="input" type="password" />
        </div>
        <div style="display:flex;gap:10px;margin-top:8px">
            <button type="submit" class="btn btn-primary">Parolayı Sıfırla</button>
            <a asp-action="Index" class="btn btn-subtle">Vazgeç</a>
        </div>
    </form>
</div>
