@model CreateUserViewModel
@{
    ViewData["Title"] = "Yeni Kullanıcı";
}
<div class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">İş Yönetimi</a>
    <span class="sep">/</span>
    <a asp-action="Index">Kullanıcılar</a>
    <span class="sep">/</span>
    <span>Yeni kullanıcı</span>
</div>
<h1 class="page-title">Yeni kullanıcı</h1>

<div class="card card-pad" style="max-width:720px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="form-errors" asp-validation-summary="All"></div>
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div class="field">
                <label asp-for="FirstName">Ad<span class="req">*</span></label>
                <input asp-for="FirstName" class="input" />
            </div>
            <div class="field">
                <label asp-for="LastName">Soyad<span class="req">*</span></label>
                <input asp-for="LastName" class="input" />
            </div>
            <div class="field">
                <label asp-for="UserName">Kullanıcı Adı<span class="req">*</span></label>
                <input asp-for="UserName" class="input" placeholder="ad.soyad" />
            </div>
            <div class="field">
                <label asp-for="Email">E-posta<span class="req">*</span></label>
                <input asp-for="Email" class="input" type="email" placeholder="ad.soyad@kosifler.com.tr" />
            </div>
            <div class="field">
                <label asp-for="Title">Unvan</label>
                <input asp-for="Title" class="input" />
            </div>
            <div class="field">
                <label asp-for="DepartmentId">Departman</label>
                <select asp-for="DepartmentId" asp-items="Model.Departments" class="select">
                    <option value="">Departman seçin</option>
                </select>
            </div>
            <div class="field">
                <label asp-for="RoleId">Rol</label>
                <select asp-for="RoleId" asp-items="Model.Roles" class="select">
                    <option value="">Rol seçin</option>
                </select>
            </div>
            <div></div>
            <div class="field">
                <label asp-for="Password">Parola<span class="req">*</span></label>
                <input asp-for="Password" class="input" type="password" />
                <div class="field-hint">En az 8 karakter, büyük harf, rakam ve sembol içermeli.</div>
            </div>
            <div class="field">
                <label asp-for="ConfirmPassword">Parola (Tekrar)<span class="req">*</span></label>
                <input asp-for="ConfirmPassword" class="input" type="password" />
            </div>
        </div>

        <div style="display:flex;gap:10px;margin-top:8px">
            <button type="submit" class="btn btn-primary">Kullanıcıyı Oluştur</button>
            <a asp-action="Index" class="btn btn-subtle">Vazgeç</a>
        </div>
    </form>
</div>
